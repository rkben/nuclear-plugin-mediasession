{
  "name": "nuclear-plugin-mediasession",
  "version": "0.1.0",
  "description": "Exposes Nuclear playback to the OS media controls via the Media Session API",
  "author": "Richard Benson",
  "license": "Unlicense",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --dts --format cjs --minify --out-dir dist",
    "dev": "tsup src/index.ts --dts --format cjs --out-dir dist --watch",
    "typecheck": "tsc --noEmit"
  },
  "nuclear": {
    "displayName": "Media Controls",
    "category": "integration"
  },
  "dependencies": {
    "@nuclearplayer/plugin-sdk": "^2.8.0"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  }
}
